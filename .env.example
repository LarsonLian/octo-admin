# Backend API base path (used by axios client)
VITE_API_BASE=/api

# Dev-mode reverse proxy target (vite server.proxy)
VITE_PROXY_TARGET=https://api-test.example.com

# Bot API URL for the connect guide (defaults to current origin if unset)
# VITE_BOT_API_URL=

# Admin API endpoints (referenced in README)
# VITE_ADMIN_API_BASE=
# VITE_ADMIN_API_TOKEN=

# octo-marketplace (Skill/MCP catalog service)
# Dev proxy target for /market/api/*. Defaults to http://127.0.0.1:8092 when
# unset. Prod deployments route /market/* to the marketplace service via
# nginx and can leave this unset.
# VITE_MARKETPLACE_TARGET=http://127.0.0.1:8092

# Base path the axios client uses when hitting the marketplace admin surface.
# Kept as /market/api/v1 to match the nginx / vite proxy rewrite.
VITE_MARKETPLACE_API_BASE=/market/api/v1

# Shared secret to reach /market/api/v1/admin/*. Must match
# MARKETPLACE_ADMIN_TOKEN on the octo-marketplace service. Leave empty in dev
# (marketplace runs with AUTH_ENABLED=false and bypasses the check).
#
# ⚠️  SECURITY — this value is inlined into the JavaScript bundle at build
# time by Vite (any `import.meta.env.VITE_*` is baked into the shipped code
# and therefore visible in the browser DevTools). Treat it as a low-value
# secret and defend in depth:
#   - marketplace MUST NOT be reachable from the public internet; front it
#     with nginx / an internal load balancer that only accepts traffic from
#     the admin console origin.
#   - Rotate this token on any suspicion of leak; the marketplace side
#     accepts a change with a redeploy of MARKETPLACE_ADMIN_TOKEN.
#   - Consider a follow-up that moves admin writes behind octo-admin's own
#     backend (BFF) so the token never touches the browser.
VITE_MARKETPLACE_ADMIN_TOKEN=dev-admin-token
